{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "routes": [
    { "src": "/inventario-captura", "dest": "/inventario-captura.html" },
    { "src": "/api/webauthn/(.*)", "dest": "/api/webauthn/$1" },
    { "src": "/api/admin/(.*)", "dest": "/api/admin/$1" },
    { "src": "/api/push/(.*)", "dest": "/api/push/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
